"""
HIL Server 文件发送功能扩展

这个补丁为 HIL Server 添加了发送文件(包括 MD 文档)的功能
"""

# ============================================
# 1. 修改 sender.py - 添加 file 类型支持
# ============================================
# 在 packages/hil-server/hil_server/sender.py 的 send_to_wecom 函数中添加:

def send_to_wecom(
    message: str,
    chat_id: str | None = None,
    bot_key: str | None = None,
    msg_type: str = "text",
    images: list[str] | None = None,
    files: dict | None = None,  # 新增: files 参数
) -> dict:
    """
    使用 fly-pigeon 库发送消息到企业微信

    新增支持:
    - msg_type="file": 发送文件消息
    """
    from pigeon import Bot

    bot_key = bot_key or config.bot_key

    if not bot_key:
        raise ValueError("未配置 bot_key")

    bot = Bot(bot_key=bot_key)

    logger.info(f"[Direct] 发送消息到企微: chat_id={chat_id}, msg_type={msg_type}")

    try:
        if msg_type == "text":
            result = bot.text(
                chat_id=chat_id,
                msg_content=message,
            )
        elif msg_type == "markdown":
            result = bot.markdown(
                chat_id=chat_id,
                msg_content=message,
            )
        elif msg_type == "image" and images:
            image_content = images[0]
            if image_content.startswith("data:"):
                image_content = image_content.split(",", 1)[1] if "," in image_content else image_content

            result = bot.image(
                msg_content=image_content,
                chat_id=chat_id,
            )
        elif msg_type == "file" and files:  # 🆕 新增: 文件发送
            # fly-pigeon 的 file 方法签名 (推测)
            # 需要先上传文件获取 media_id
            media_id = files.get("media_id")
            safe = files.get("safe", 0)

            if not media_id:
                raise ValueError("发送文件需要提供 media_id")

            # 假设 fly-pigeon 支持 file 方法
            result = bot.file(
                chat_id=chat_id,
                media_id=media_id,
                safe=safe
            )
        else:
            result = bot.text(
                chat_id=chat_id,
                msg_content=message,
            )

        logger.info(f"[Direct] fly-pigeon 响应: {result}")
        return result or {"errcode": 0, "errmsg": "ok"}

    except Exception as e:
        logger.error(f"[Direct] fly-pigeon 发送失败: {e}", exc_info=True)
        raise


# ============================================
# 2. 添加文件上传 API (类似 upload-image)
# ============================================
# 在 packages/hil-server/hil_server/handlers/api.py 中添加:

from fastapi import UploadFile, File

class UploadFileResponse(BaseModel):
    """上传文件响应"""
    success: bool
    media_id: str | None = None
    error: str | None = None


@router.post("/upload-file", response_model=UploadFileResponse)
async def upload_file(file: UploadFile = File(...)):
    """
    上传文件到企业微信

    返回 media_id,用于后续发送文件消息
    """
    # 检查 Direct 模式
    if not config.is_direct_mode and not ws_manager.has_worker:
        return UploadFileResponse(
            success=False,
            error="没有可用的 Worker 连接"
        )

    try:
        # 读取文件内容
        content = await file.read()
        filename = file.filename

        if config.is_direct_mode:
            # Direct 模式: 调用 fly-pigeon 上传文件
            from pigeon import Bot
            bot = Bot(bot_key=config.bot_key)

            # 假设 fly-pigeon 有 upload_file 方法
            # 实际方法名需要查看 fly-pigeon 文档
            result = bot.upload_file(
                file_content=content,
                filename=filename
            )

            media_id = result.get("media_id")

            return UploadFileResponse(
                success=True,
                media_id=media_id
            )
        else:
            # Relay 模式: 转发到 Worker
            import base64
            b64_content = base64.b64encode(content).decode("utf-8")

            response = await ws_manager.send_request(
                action="upload_file",
                payload={
                    "content": b64_content,
                    "filename": filename,
                    "content_type": file.content_type
                },
                timeout=60  # 文件上传可能需要更长时间
            )

            return UploadFileResponse(
                success=True,
                media_id=response.get("media_id")
            )

    except Exception as e:
        logger.error(f"上传文件失败: {e}", exc_info=True)
        return UploadFileResponse(
            success=False,
            error=str(e)
        )


