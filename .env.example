# ==========================================
# HITL Server 配置示例
# ==========================================
# 复制此文件为 .env 并按需填写。
# HITL Server 为本地单进程服务，内置 ilink + wecom-aibot 两个引擎。
# 大部分配置也可在管理台（/console）运行时操作，此处仅作启动期默认值。

# ── 服务 ───────────────────────────────────────────────
# 服务监听端口
HITL_PORT=8081
# 服务监听地址
HITL_HOST=0.0.0.0

# ── 内置引擎：iLink（个人微信）────────────────────────
# 启用 iLink 内置引擎（进程内维持长轮询）
ENABLE_ILINK_ENGINE=true
# iLink 引擎的 bot_key（MCP 端按此路由）
ILINK_BOT_KEY=ilink-bot-1
# iLink API 地址
ILINK_BASE_URL=https://ilinkai.weixin.qq.com
# iLink 凭证存储路径（建议绝对路径）
# ILINK_TOKEN_STORE_PATH=~/.hil-mcp/ilink_store.json

# ── 内置引擎：企业微信 AI Bot ─────────────────────────
# 启用企微 AI Bot 内置引擎（也可在管理台运行时启动，凭证落盘后重启自动恢复）
# ENABLE_WECOM_AIBOT_ENGINE=true
# WECOM_AIBOT_BOT_ID=
# WECOM_AIBOT_BOT_SECRET=
# WECOM_AIBOT_BOT_KEY=wecom-aibot-1
# WECOM_AIBOT_WS_URL=wss://openws.work.weixin.qq.com

# ── 数据存储 ───────────────────────────────────────────
# 会话数据存储目录
DATA_DIR=./data
# 启用数据库（替代 JSON 文件存储）
# USE_DATABASE=true
# DATABASE_URL=sqlite+aiosqlite:///./data/service.db
# 会话过期时间（秒），默认 1 小时
SESSION_EXPIRE_SECONDS=3600

# ── 共享部署模式（一个企微 AI Bot 服务全员）──────────────
# 开启后：HITL_SERVER 部署在服务器端，/api/* 强制鉴权，wecom-aibot 不再回退
# 到全局最近活跃收件人（chat_id 必填），用户首次给 bot 发消息时自动回告 chat_id。
# HITL_SHARED_MODE=true
# 单一 API Key（Bearer Token）；持有者可对任意 chat_id 发消息。多租户用下面的 tokens。
# HITL_API_KEY=
# 多租户 token→chat_id 白名单，JSON 字符串。空数组表示该 token 不限制 chat_id。
# 例：{"tokenTom":["tom_userid"],"tokenGroupA":["group_chatid_a"]}
# HITL_API_TOKENS=

# ── 管理台认证 ─────────────────────────────────────────
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
# ADMIN_TOKEN_SECRET=change-me
